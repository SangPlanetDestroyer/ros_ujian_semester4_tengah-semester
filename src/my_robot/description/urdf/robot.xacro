<?xml version="1.0"?>
<robot name="my_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ================= PROPERTIES ================= -->
  <xacro:property name="x_l" value="-0.029"/>
  <xacro:property name="y_l" value="0.052"/>
  <xacro:property name="z_l" value="0.008"/>

  <xacro:property name="x_r" value="-0.029"/>
  <xacro:property name="y_r" value="-0.052"/>
  <xacro:property name="z_r" value="0.008"/>

  <xacro:property name="x_c" value="0.038"/>
  <xacro:property name="y_c" value="0.00"/>
  <xacro:property name="z_c" value="0.00"/>

  <xacro:property name="x_imu" value="0.033"/>
  <xacro:property name="y_imu" value="0.0"/>
  <xacro:property name="z_imu" value="0.024"/>

  <!-- UPDATED PARAMETERS -->
  <xacro:property name="mu_drive" value="1.0"/>
  <xacro:property name="mu_drive_lateral" value="1.3"/>
  <xacro:property name="mu_caster" value="0.01"/>
  <xacro:property name="caster_slip1" value="0.15"/>
  <xacro:property name="caster_slip2" value="0.15"/>
  <xacro:property name="wheel_damping" value="1.5"/>

  <xacro:property name="wheel_left_slip1" value="0.005"/>
  <xacro:property name="wheel_left_slip2" value="0.005"/>
  <xacro:property name="wheel_right_slip1" value="0.005"/>
  <xacro:property name="wheel_right_slip2" value="0.005"/>

  <!-- ================= BASE ================= -->
  <link name="base_link">

    <inertial>
      <mass value="2.0"/>
      <origin xyz="-0.015 0 0" rpy="0 0 0"/>
      <inertia ixx="0.01" iyy="0.015" izz="0.02"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 1.5708"/>
      <geometry>
        <mesh filename="package://my_robot/description/meshes/body.dae" scale="1.0 1.0 1.0"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 0.026" rpy="0 0 0"/>
      <geometry>
        <box size="0.099 0.086 0.05379345"/>
      </geometry>
    </collision>

  </link>

  <!-- ================= LEFT WHEEL ================= -->
  <link name="left_wheel">

    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <!-- IMPROVED INERTIA -->
      <inertia ixx="0.0002" iyy="0.0001" izz="0.0002"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  
    <visual>
      <origin xyz="0 0 0" rpy="0 0 1.5708"/>
      <geometry>
        <mesh filename="package://my_robot/description/meshes/roda2.dae" scale="1.0 1.0 1.0"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.02131869" length="0.017"/>
      </geometry>
      <surface>
        <friction>
          <ode>
            <mu>${mu_drive}</mu>
            <mu2>${mu_drive_lateral}</mu2>
            <slip1>${wheel_left_slip1}</slip1>
            <slip2>${wheel_left_slip2}</slip2>
            <fdir1>1 0 0</fdir1>
          </ode>
        </friction>
      </surface>
    </collision>

  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="${x_l} ${y_l} ${z_l}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="${wheel_damping}" friction="0.0"/>
  </joint>

  <!-- ================= RIGHT WHEEL ================= -->
  <link name="right_wheel">

    <inertial>
      <mass value="0.2"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <!-- IMPROVED INERTIA -->
      <inertia ixx="0.0002" iyy="0.0001" izz="0.0002"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 1.5708"/>
      <geometry>
        <mesh filename="package://my_robot/description/meshes/roda1.dae" scale="1.0 1.0 1.0"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry>
        <cylinder radius="0.02131869" length="0.017"/>
      </geometry>
      <surface>
        <friction>
          <ode>
            <mu>${mu_drive}</mu>
            <mu2>${mu_drive_lateral}</mu2>
            <slip1>${wheel_right_slip1}</slip1>
            <slip2>${wheel_right_slip2}</slip2>
            <fdir1>1 0 0</fdir1>
          </ode>
        </friction>
      </surface>
    </collision>

  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="${x_r} ${y_r} ${z_r}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <dynamics damping="${wheel_damping}" friction="0.0"/>
  </joint>

  <!-- ================= CASTER ================= -->
  <link name="caster_wheel">

    <inertial>
      <mass value="0.02"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.000002" iyy="0.000002" izz="0.000002"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>

    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <mesh filename="package://my_robot/description/meshes/freewheel.dae" scale="1.0 1.0 1.0"/>
      </geometry>
    </visual>

    <collision>
      <origin xyz="0 0 -0.007" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.006"/>
      </geometry>
      <surface>
        <friction>
          <ode>
            <mu>${mu_caster}</mu>
            <mu2>${mu_caster}</mu2>
            <slip1>${caster_slip1}</slip1>
            <slip2>${caster_slip2}</slip2>
          </ode>
        </friction>
      </surface>
    </collision>

  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="${x_c} ${y_c} ${z_c}" rpy="0 0 0"/>
  </joint>

  <!-- ================= IMU ================= -->
  <link name="imu_link">
    <inertial>
      <mass value="0.01"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <inertia ixx="0.000001" iyy="0.000001" izz="0.000001"
               ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="imu_joint" type="fixed">
    <parent link="base_link"/>
    <child link="imu_link"/>
    <origin xyz="${x_imu} ${y_imu} ${z_imu}" rpy="0 0 0"/>
  </joint>

  <gazebo reference="imu_link">
    <sensor name="imu_sensor" type="imu">
      <always_on>true</always_on>
      <update_rate>100</update_rate>
      <topic>/imu</topic>
      <imu>
        <angular_velocity>
          <x>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.0002</stddev>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.0002</stddev>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.0002</stddev>
            </noise>
          </z>
        </angular_velocity>
        <linear_acceleration>
          <x>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.017</stddev>
            </noise>
          </x>
          <y>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.017</stddev>
            </noise>
          </y>
          <z>
            <noise type="gaussian">
              <mean>0.0</mean>
              <stddev>0.017</stddev>
            </noise>
          </z>
        </linear_acceleration>
      </imu>
    </sensor>
  </gazebo>

  <gazebo>
    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.104</wheel_separation>
      <wheel_radius>0.02131869</wheel_radius>
      <max_linear_velocity>1.0</max_linear_velocity>
      <max_angular_velocity>2.0</max_angular_velocity>
      <linear_acceleration_limit>1.0</linear_acceleration_limit>
      <angular_acceleration_limit>2.0</angular_acceleration_limit>
      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <tf_topic>/tf</tf_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <publish_wheel_tf>false</publish_wheel_tf>
      <publish_odom_tf>true</publish_odom_tf>
    </plugin>
    
  <plugin filename="gz-sim-linearbatteryplugin-system"
    name="gz::sim::systems::LinearBatteryPlugin">
    <!--Li-ion battery spec from LIR18650 datasheet-->
    <battery_name>linear_battery</battery_name>
    <voltage>4.2</voltage>
    <open_circuit_voltage_constant_coef>4.2</open_circuit_voltage_constant_coef>
    <open_circuit_voltage_linear_coef>-2.0</open_circuit_voltage_linear_coef>
    <initial_charge>2.5</initial_charge>
    <capacity>2.5 </capacity>
    <resistance>0.07</resistance>
    <smooth_current_tau>2.0</smooth_current_tau>
    <enable_recharge>false</enable_recharge>
    <charging_time>3.0</charging_time>
    <soc_threshold>0.51</soc_threshold>
    <!-- Consumer-specific -->
    <power_load>2.1</power_load>
    <start_on_motion>true</start_on_motion>
  </plugin>
  </gazebo>

</robot>